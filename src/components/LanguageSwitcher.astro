---
import type { Lang, RouteName } from '../i18n/utils';
import { allRoutes } from '../i18n/utils';

interface Props {
  lang: Lang;
  routeName: RouteName;
  mobile?: boolean;
}
const { lang, routeName, mobile = false } = Astro.props;

const langs: { code: Lang; label: string; flag: string }[] = [
  { code: 'it', label: 'IT', flag: '🇮🇹' },
  { code: 'en', label: 'EN', flag: '🇬🇧' },
  { code: 'de', label: 'DE', flag: '🇩🇪' },
];
---

{mobile ? (
  <div class="flex gap-2 flex-wrap">
    {langs.map(l => (
      <a
        href={allRoutes[routeName][l.code]}
        class={`px-3 py-1.5 rounded-md text-sm font-medium transition-colors ${
          l.code === lang
            ? 'bg-sand-400 text-sea-900'
            : 'text-white/70 hover:text-white hover:bg-white/10'
        }`}
        aria-current={l.code === lang ? 'true' : undefined}
      >
        {l.flag} {l.label}
      </a>
    ))}
  </div>
) : (
  <div class="relative group">
    <button class="flex items-center gap-1 text-white/90 hover:text-white text-sm font-medium px-2 py-2 rounded-md hover:bg-white/10 transition-colors" aria-haspopup="true">
      {langs.find(l => l.code === lang)?.flag}
      <span>{lang.toUpperCase()}</span>
      <svg class="w-3 h-3 ml-0.5 opacity-70" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7" />
      </svg>
    </button>
    <div class="absolute right-0 top-full mt-1 w-28 bg-sea-900 border border-white/10 rounded-lg shadow-xl py-1 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
      {langs.map(l => (
        <a
          href={allRoutes[routeName][l.code]}
          class={`flex items-center gap-2 px-3 py-2 text-sm hover:bg-white/10 transition-colors ${
            l.code === lang ? 'text-sand-300 font-semibold' : 'text-white/80 hover:text-white'
          }`}
          aria-current={l.code === lang ? 'true' : undefined}
        >
          {l.flag} {l.label}
        </a>
      ))}
    </div>
  </div>
)}
