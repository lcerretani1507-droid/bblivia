---
import Layout from '../../layouts/Layout.astro';
import ApartmentCard from '../../components/ApartmentCard.astro';
import BookingCTA from '../../components/BookingCTA.astro';
import FAQ from '../../components/FAQ.astro';
import { useTranslations } from '../../i18n/utils';
import config from '../../../data/config.json';
import apartments from '../../../data/apartments.json';
import faqData from '../../../data/faq.json';

const lang = 'de';
const t = useTranslations(lang);
const aptFaqs = faqData.filter(f => ['animali', 'checkin-checkout', 'bagagli', 'distanza-mare'].includes(f.id));
const aptSchemas = apartments.map(apt => ({
  "@context": "https://schema.org", "@type": "Apartment",
  "name": apt.name[lang], "description": apt.description[lang], "image": apt.image,
  "numberOfBedrooms": apt.bedrooms, "numberOfBathroomsTotal": apt.bathrooms,
  "occupancy": { "@type": "QuantitativeValue", "maxValue": apt.maxGuests }, "petsAllowed": apt.petsAllowed,
  "amenityFeature": apt.amenities.map(a => ({ "@type": "LocationFeatureSpecification", "name": t.amenities[a as keyof typeof t.amenities] ?? a, "value": true })),
  "potentialAction": { "@type": "ReserveAction", "target": { "@type": "EntryPoint", "urlTemplate": config.siteUrl + t.routes.book } }
}));
---

<Layout lang={lang} routeName="apartments" title={t.apartments.title} description={t.apartments.metaDescription} extraSchemas={aptSchemas}
  breadcrumbs={[{ name: 'Startseite', url: config.siteUrl + t.routes.home },{ name: t.apartments.title, url: config.siteUrl + t.routes.apartments }]}>
  <section class="relative h-64 sm:h-80 flex items-center justify-center overflow-hidden -mt-20">
    <div class="absolute inset-0">
      <img src="https://images.unsplash.com/photo-1502672260266-1c1ef2d93688?w=1200&q=80" alt="Strandnahe Apartments Castiglione della Pescaia" class="w-full h-full object-cover" />
      <div class="absolute inset-0 bg-sea-900/55"></div>
    </div>
    <div class="relative z-10 text-center text-white px-4">
      <h1 class="font-serif text-4xl sm:text-5xl font-bold drop-shadow-md mb-3">{t.apartments.hero}</h1>
      <p class="text-white/80 text-lg">{t.apartments.subtitle}</p>
    </div>
  </section>
  <section class="bg-sand-100 border-b border-sand-200 py-4 px-4">
    <div class="max-w-4xl mx-auto flex flex-wrap items-center justify-center gap-x-8 gap-y-2 text-sm text-sea-800">
      <span class="flex items-center gap-1.5">🐾 {t.apartments.petsAllowed}</span>
      <span class="flex items-center gap-1.5">🍳 {t.amenities['kitchen']}</span>
      <span class="flex items-center gap-1.5">🌊 {t.amenities['sea-view']}</span>
      <span class="flex items-center gap-1.5">🚗 {t.amenities['parking']}</span>
    </div>
  </section>
  <section class="py-12 px-4 bg-warm-100"><div class="max-w-3xl mx-auto text-center"><p class="text-sea-700 text-lg leading-relaxed">{t.apartments.intro}</p></div></section>
  <section class="py-12 px-4 pb-20 bg-warm-100">
    <div class="max-w-5xl mx-auto grid grid-cols-1 sm:grid-cols-2 gap-8">
      {apartments.map(apt => <ApartmentCard apartment={apt} lang={lang} />)}
    </div>
  </section>
  <BookingCTA lang={lang} />
  <section class="py-16 px-4 bg-warm-100">
    <div class="max-w-3xl mx-auto">
      <h2 class="font-serif text-2xl font-bold text-sea-900 mb-8 text-center">{t.apartments.faqTitle}</h2>
      <FAQ lang={lang} items={aptFaqs} />
    </div>
  </section>
</Layout>
