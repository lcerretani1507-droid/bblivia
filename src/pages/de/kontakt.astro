---
import Layout from '../../layouts/Layout.astro';
import FAQ from '../../components/FAQ.astro';
import BookingCTA from '../../components/BookingCTA.astro';
import { useTranslations } from '../../i18n/utils';
import config from '../../../data/config.json';
import faqData from '../../../data/faq.json';

const lang = 'de';
const t = useTranslations(lang);
const faqSchema = { "@context": "https://schema.org", "@type": "FAQPage", "mainEntity": faqData.map(f => ({ "@type": "Question", "name": f.question[lang], "acceptedAnswer": { "@type": "Answer", "text": f.answer[lang] } })) };
---

<Layout lang={lang} routeName="contact" title={t.contact.title} description={t.contact.metaDescription} extraSchemas={[faqSchema]}
  breadcrumbs={[{ name: 'Startseite', url: config.siteUrl + t.routes.home },{ name: t.contact.title, url: config.siteUrl + t.routes.contact }]}>
  <section class="relative h-56 sm:h-72 flex items-center justify-center overflow-hidden -mt-20">
    <div class="absolute inset-0">
      <img src="https://images.unsplash.com/photo-1543716091-a840c05249ec?w=1200&q=80" alt="Kontakt B&B Castiglione della Pescaia" class="w-full h-full object-cover" />
      <div class="absolute inset-0 bg-sea-900/60"></div>
    </div>
    <div class="relative z-10 text-center text-white px-4">
      <h1 class="font-serif text-4xl sm:text-5xl font-bold drop-shadow-md mb-2">{t.contact.hero}</h1>
      <p class="text-white/75 text-lg">{t.contact.subtitle}</p>
    </div>
  </section>
  <section class="py-16 px-4 bg-warm-100">
    <div class="max-w-5xl mx-auto">
      <p class="text-sea-700 text-lg text-center max-w-2xl mx-auto mb-12">{t.contact.intro}</p>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 mb-12">
        <a href={`tel:${config.phone}`} class="flex flex-col items-center gap-3 p-6 bg-white rounded-2xl shadow-sm hover:shadow-md transition-shadow text-center group">
          <div class="w-12 h-12 bg-sea-100 rounded-full flex items-center justify-center group-hover:bg-sea-200 transition-colors"><svg class="w-6 h-6 text-sea-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg></div>
          <div><p class="text-xs text-sea-500 uppercase tracking-wider font-semibold mb-1">{t.contact.phone}</p><p class="text-sea-900 font-semibold">{config.phone}</p></div>
        </a>
        <a href={`mailto:${config.email}`} class="flex flex-col items-center gap-3 p-6 bg-white rounded-2xl shadow-sm hover:shadow-md transition-shadow text-center group">
          <div class="w-12 h-12 bg-sea-100 rounded-full flex items-center justify-center group-hover:bg-sea-200 transition-colors"><svg class="w-6 h-6 text-sea-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg></div>
          <div><p class="text-xs text-sea-500 uppercase tracking-wider font-semibold mb-1">{t.contact.email}</p><p class="text-sea-900 font-semibold break-all">{config.email}</p></div>
        </a>
        <div class="flex flex-col items-center gap-3 p-6 bg-white rounded-2xl shadow-sm text-center">
          <div class="w-12 h-12 bg-sea-100 rounded-full flex items-center justify-center"><svg class="w-6 h-6 text-sea-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg></div>
          <div><p class="text-xs text-sea-500 uppercase tracking-wider font-semibold mb-1">{t.contact.address}</p><p class="text-sea-900 font-semibold text-sm">{config.address.full}</p></div>
        </div>
      </div>
      <div class="bg-sea-900 text-white rounded-2xl p-6 text-center max-w-md mx-auto">
        <p class="text-sand-300 text-sm font-semibold uppercase tracking-wider mb-3">Check-in / Check-out</p>
        <div class="flex justify-center gap-10">
          <div><p class="font-serif text-3xl font-bold text-sand-300">{config.checkinTime}</p><p class="text-white/60 text-xs mt-0.5">Check-in</p></div>
          <div class="border-l border-white/20"></div>
          <div><p class="font-serif text-3xl font-bold text-sand-300">{config.checkoutTime}</p><p class="text-white/60 text-xs mt-0.5">Check-out</p></div>
        </div>
      </div>
    </div>
  </section>
  <section class="py-16 px-4 bg-white">
    <div class="max-w-5xl mx-auto">
      <h2 class="font-serif text-2xl font-bold text-sea-900 text-center mb-8">{t.contact.mapTitle}</h2>
      <div class="rounded-2xl overflow-hidden shadow-lg h-72 sm:h-96">
        <iframe src={`https://maps.google.com/maps?q=${config.coordinates.lat},${config.coordinates.lng}&z=15&output=embed`} width="100%" height="100%" style="border:0;" allowfullscreen loading="lazy" referrerpolicy="no-referrer-when-downgrade" title={`${config.propertyName} - ${config.address.full}`}></iframe>
      </div>
    </div>
  </section>
  <section class="py-16 px-4 bg-warm-100">
    <div class="max-w-3xl mx-auto">
      <h2 class="font-serif text-3xl font-bold text-sea-900 mb-10 text-center">{t.contact.faqTitle}</h2>
      <FAQ lang={lang} items={faqData} />
    </div>
  </section>
  <BookingCTA lang={lang} />
</Layout>
