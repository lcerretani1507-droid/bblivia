---
import Layout from '../../layouts/Layout.astro';
import { useTranslations } from '../../i18n/utils';
import config from '../../../data/config.json';

const lang = 'en';
const t = useTranslations(lang);
---

<Layout lang={lang} routeName="book" title={t.book.title} description={t.book.metaDescription}
  breadcrumbs={[{ name: 'Home', url: config.siteUrl + t.routes.home },{ name: t.book.title, url: config.siteUrl + t.routes.book }]}>
  <div class="bg-warm-100">
    <div class="bg-sea-900 text-white px-4 py-3 flex items-center justify-between">
      <a href={t.routes.home} class="inline-flex items-center gap-2 text-white/80 hover:text-white text-sm transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
        {t.book.backToSite}
      </a>
      <span class="font-serif text-base font-semibold hidden sm:block">{config.propertyName}</span>
      <div class="w-24"></div>
    </div>
    <div class="flex flex-col items-center px-4 py-10">
      <h1 class="font-serif text-3xl font-bold text-sea-900 mb-2 text-center">{t.book.hero}</h1>
      <p class="text-sea-600 mb-8 text-center">{config.propertyName} · Castiglione della Pescaia</p>
      {config.bookingIframeUrl === 'https://BOOKING-ENGINE-URL' ? (
        <div class="w-full max-w-3xl bg-white rounded-2xl shadow-sm border-2 border-dashed border-sea-200 p-16 text-center">
          <svg class="w-16 h-16 text-sea-300 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
          <h2 class="font-serif text-xl font-bold text-sea-700 mb-3">Booking Engine</h2>
          <p class="text-sea-500 text-sm max-w-sm mx-auto mb-6">Set the booking engine URL in <code class="bg-sea-50 px-1.5 py-0.5 rounded text-sea-700 font-mono text-xs">data/config.json</code> under the <code class="bg-sea-50 px-1.5 py-0.5 rounded text-sea-700 font-mono text-xs">bookingIframeUrl</code> field.</p>
          <div class="flex flex-col sm:flex-row gap-3 justify-center">
            <a href={`tel:${config.phone}`} class="px-6 py-3 bg-sea-700 hover:bg-sea-600 text-white font-semibold rounded-full transition-colors">{config.phone}</a>
            <a href={`mailto:${config.email}`} class="px-6 py-3 border-2 border-sea-700 text-sea-700 hover:bg-sea-700 hover:text-white font-semibold rounded-full transition-all">{config.email}</a>
          </div>
        </div>
      ) : (
        <div class="w-full max-w-5xl rounded-2xl overflow-hidden shadow-lg">
          <iframe src={config.bookingIframeUrl} width="100%" height="800" style="border:0; min-height: 600px;" title={`Book - ${config.propertyName}`} loading="lazy"></iframe>
        </div>
      )}
    </div>
  </div>
</Layout>
